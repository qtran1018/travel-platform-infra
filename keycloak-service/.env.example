# Copy to .env (gitignored) and fill in. Generate strong values: openssl rand -base64 32
#
# PRODUCTION LANDMINES (existing OCI deployment):
#  - KEYCLOAK_DB_PASSWORD must equal the password already in the keycloak_pgdata
#    volume (originally "keycloak"). A different value breaks Keycloak's DB
#    connection and takes down all SSO. To rotate: exec into keycloak-db and run
#    ALTER USER keycloak PASSWORD '<new>'; then update this value.
#  - KEYCLOAK_ADMIN_PASSWORD only seeds the admin on FIRST boot. The live admin
#    password is unchanged by this var — rotate it via the admin console or kcadm.

KEYCLOAK_DB_PASSWORD=
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=
